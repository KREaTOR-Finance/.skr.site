# Copy to local.properties and adjust values for your environment.
# Android SDK path is still required by Gradle:
# sdk.dir=C\:\\Users\\<you>\\AppData\\Local\\Android\\Sdk

# Storage provider used by the mobile upload adapter: arweave or ipfs
STORAGE_PROVIDER=arweave

# Upload service base URL (emulator default for localhost web gateway)
UPLOAD_API_BASE_URL=http://10.0.2.2:3000

# Optional direct-provider credentials (for controlled/internal builds only)
ARWEAVE_JWK=
PINATA_JWT=

# Release signing (required for assembleRelease / bundleRelease)
RELEASE_STORE_FILE=
RELEASE_STORE_PASSWORD=
RELEASE_KEY_ALIAS=
RELEASE_KEY_PASSWORD=

# Chain defaults
CHAIN_NETWORK=mainnet
SOLANA_RPC_URLS=https://api.mainnet-beta.solana.com,https://solana-mainnet.g.alchemy.com/v2/demo
